# Discourse Putzplan-Reminder Konfiguration
# Kopiere diese Datei nach .env und trage die Werte ein:
#   cp .env.example .env

# Forum-URL (ohne Slash am Ende)
DISCOURSE_URL=https://forum.example.com

# API-Key des Bot-Users (Admin > API > Keys)
DISCOURSE_API_KEY=dein_api_key_hier

# Bot-Username
DISCOURSE_API_USERNAME=Putzbot

# Topic-ID des Putzplan-Topics
DISCOURSE_TOPIC_ID=3513

# Post-ID mit der Putzplan-Tabelle (optional)
# Wenn nicht gesetzt, wird automatisch der neueste Post mit einer
# gueltigen Tabelle (mind. 3 Wochen) im Topic gesucht.
# Hinweis: Die Post-ID ist NICHT die Nummer in der URL (/t/slug/3513/95),
# sondern eine interne ID. Findbar via API:
#   GET https://forum.example.com/t/3513.json → post_stream.stream[]
# DISCOURSE_SCHEDULE_POST_ID=63560

# Discourse-Gruppen fuer den Abgleich (optional, kommagetrennt)
# Mitglieder dieser Gruppen, die noch keinen Putzdienst eingetragen haben,
# werden im Reminder namentlich erwaehnt.
DISCOURSE_MEMBER_GROUPS=anwaerter,mitglieder

# User die vom Putzplan ausgenommen sind (optional, kommagetrennt)
# Diese werden nie erwaehnt, auch wenn sie in den Gruppen oben sind.
# DISCOURSE_EXCLUDE_USERS=admin,hausmeister,altmieter1
